<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>SoraV2BatteryTip</RootNamespace>
    <AssemblyName>SoraV2BatteryTip</AssemblyName>
    <AssemblyTitle>Sora V2 Battery Tip</AssemblyTitle>
    <Product>Sora V2 Battery Tip</Product>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWindowsForms>true</UseWindowsForms>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\SoraV2BatteryTip.ico</ApplicationIcon>
    <PublishReadyToRun>false</PublishReadyToRun>
    <RestoreIgnoreFailedSources>true</RestoreIgnoreFailedSources>
    <NuGetAudit>false</NuGetAudit>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="Assets\SoraV2BatteryTip.ico" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
    <Content Include="Assets\*.wav" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="HidSharp"><HintPath>Libs\HidSharp.dll</HintPath><Private>true</Private></Reference>
  </ItemGroup>
</Project>

